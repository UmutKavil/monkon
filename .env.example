# monkon Configuration

# Web root directory
MONKON_WEB_ROOT=~/monkon/www

# Config directory
MONKON_CONFIG_DIR=~/.monkon

# PHP Version (supported: 7.4, 8.0, 8.1, 8.2, 8.3)
PHP_VERSION=8.3

# MySQL Version (supported: 5.7, 8.0)
MYSQL_VERSION=8.0

# Services to start by default
ENABLE_APACHE=true
ENABLE_MYSQL=true
ENABLE_PHPMYADMIN=true

# PhpMyAdmin settings
PHPMYADMIN_PORT=80
PHPMYADMIN_PATH=/phpmyadmin

# MySQL Settings
MYSQL_ROOT_PASSWORD=REPLACE_WITH_SECURE_ROOT_PASSWORD
MYSQL_USER=REPLACE_WITH_DB_USERNAME
MYSQL_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
MYSQL_PORT=3306

# Apache Settings
APACHE_PORT=80
APACHE_SSL_PORT=443

# Memory limits
PHP_MEMORY_LIMIT=512M
MYSQL_MEMORY_LIMIT=256M

# Auto-start on login
AUTOSTART_ON_LOGIN=false

# Debug mode
DEBUG=false
