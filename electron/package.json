{
  "name": "monkon-desktop",
  "version": "0.1.0",
  "description": "monkon Desktop Application",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^latest"
  },
  "build": {
    "appId": "com.monkon.app",
    "productName": "monkon",
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "contents": [
        {"x": 110, "y": 150, "type": "file"},
        {"x": 240, "y": 150, "type": "link", "path": "/Applications"}
      ]
    }
  }
}
